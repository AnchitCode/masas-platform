# Server
NODE_ENV=development
PORT=5000

# Database Safety
DATABASE_BRANCH=production
PRODUCTION_DATABASE_HOST=your-production-neon-hostname.neon.tech

# Database (NeonDB)
DATABASE_URL=postgresql://user:password@host:5432/masas?sslmode=require

# Authentication
JWT_ACCESS_SECRET=your-access-secret-min-32-chars-here
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=MASAS <noreply@masas.com>

# CORS
CLIENT_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
